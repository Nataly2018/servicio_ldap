					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Arial" size="8"/>
					</textElement>
					<textFieldExpression><![CDATA[$F{evaluacion}]]></textFieldExpression>
				</textField>
			</frame>
		</band>
	</detail>
</jasperReport>
